
@model IEnumerable<DanceStudio.Domain.Model.AgeCategory>

@{
    ViewData["Title"] = "Вікові категорії";
}

<h1>Танцювальна студія</h1>

<h2>Вікові категорії</h2>

<p>
    <a href="/AgeCategories/Create" style="display: inline-block; padding: 5px 10px; background-color: #007bff; color: white; text-decoration: none; border-radius: 3px;">Додати категорію</a>
</p>

<table style="width: 100%; border-collapse: collapse; margin-top: 20px;">
    <thead>
        <tr style="background-color: #f2f2f2;">
            <th style="padding: 10px; text-align: left; border-bottom: 1px solid #ddd;">ID</th>
            <th style="padding: 10px; text-align: left; border-bottom: 1px solid #ddd;">Назва</th>
            <th style="padding: 10px; text-align: left; border-bottom: 1px solid #ddd;">Мін. вік</th>
            <th style="padding: 10px; text-align: left; border-bottom: 1px solid #ddd;">Макс. вік</th>
            <th style="padding: 10px; text-align: left; border-bottom: 1px solid #ddd;">Кількість груп</th>
            <th style="padding: 10px; text-align: left; border-bottom: 1px solid #ddd;">Дії</th>
         </thead>
    <tbody>
@foreach (var item in Model) {
          <tr>
            <td style="padding: 10px; border-bottom: 1px solid #ddd;">@item.Id</td>
            <td style="padding: 10px; border-bottom: 1px solid #ddd;">@item.Title</td>
            <td style="padding: 10px; border-bottom: 1px solid #ddd;">@item.MinAge</td>
            <td style="padding: 10px; border-bottom: 1px solid #ddd;">@item.MaxAge</td>
            <td style="padding: 10px; border-bottom: 1px solid #ddd;">@(item.Groups?.Count ?? 0)</td>
            <td style="padding: 10px; border-bottom: 1px solid #ddd;">
                <a href="/AgeCategories/Edit/@item.Id" style="color: #007bff;">Edit</a> |
                <a href="/AgeCategories/Details/@item.Id" style="color: #17a2b8;">Details</a> |
                <a href="/AgeCategories/Delete/@item.Id" style="color: #dc3545;">Delete</a>
            </td>
          </tr>
}
    </tbody>
</table>

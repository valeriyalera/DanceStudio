@{
    ViewData["Title"] = "Імпорт груп з Excel";
}

<h2>Імпорт груп з Excel-файлу</h2>

<form asp-action="Import" method="post" enctype="multipart/form-data">
    <div class="form-group">
        <label>Оберіть Excel-файл</label>
        <input type="file" name="fileExcel" class="form-control" accept=".xlsx" />
    </div>
    <button type="submit" class="btn btn-primary">Завантажити</button>
    <a asp-action="Index" class="btn btn-secondary">Скасувати</a>
</form>

<p class="mt-3 text-muted">
    Очікуваний формат файлу: один аркуш із заголовками: 
    <strong>Стиль, Вікова категорія, Рівень, Ім'я тренера, Прізвище тренера</strong>.
    Рівень може бути: "Початківець", "Середній", "Просунутий".
</p>
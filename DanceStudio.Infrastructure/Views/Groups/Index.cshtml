
@model IEnumerable<DanceStudio.Domain.Model.Group>

@{
    ViewData["Title"] = "Групи";
    string[] levels = { "Початківець", "Середній", "Просунутий" };
}

<h1>Танцювальна студія</h1>

<h2>Групи</h2>

<p>
    <a href="/Groups/Create" style="display: inline-block; padding: 5px 10px; background-color: #007bff; color: white; text-decoration: none; border-radius: 3px;">Створити групу</a>
</p>

<table style="width: 100%; border-collapse: collapse; margin-top: 20px;">
    <thead>
        <tr style="background-color: #f2f2f2;">
            <th style="padding: 10px; text-align: left; border-bottom: 1px solid #ddd;">ID</th>
            <th style="padding: 10px; text-align: left; border-bottom: 1px solid #ddd;">Стиль</th>
            <th style="padding: 10px; text-align: left; border-bottom: 1px solid #ddd;">Вікова категорія</th>
            <th style="padding: 10px; text-align: left; border-bottom: 1px solid #ddd;">Рівень</th>
            <th style="padding: 10px; text-align: left; border-bottom: 1px solid #ddd;">Тренер</th>
            <th style="padding: 10px; text-align: left; border-bottom: 1px solid #ddd;">Кількість розкладів</th>
            <th style="padding: 10px; text-align: left; border-bottom: 1px solid #ddd;">Дії</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td style="padding: 10px; border-bottom: 1px solid #ddd;">@item.Id</td>
            <td style="padding: 10px; border-bottom: 1px solid #ddd;">@item.Style?.Name</td>
            <td style="padding: 10px; border-bottom: 1px solid #ddd;">@item.AgeCategory?.Title</td>
            <td style="padding: 10px; border-bottom: 1px solid #ddd;">@item.Level</td>
            <td style="padding: 10px; border-bottom: 1px solid #ddd;">@item.Coach?.FirstName @item.Coach?.LastName</td>
            <td style="padding: 10px; border-bottom: 1px solid #ddd;">@(item.Schedules?.Count ?? 0)</td>
            <td style="padding: 10px; border-bottom: 1px solid #ddd;">
                <a href="/Groups/Edit/@item.Id" style="color: #007bff;">Edit</a> |
                <a href="/Groups/Details/@item.Id" style="color: #17a2b8;">Details</a> |
                <a href="/Groups/Delete/@item.Id" style="color: #dc3545;">Delete</a>
            </td>
        </tr>
}
<p>
    <a asp-action="Create" class="btn btn-primary">Створити групу</a>
    <a asp-action="Import" class="btn btn-secondary">Імпорт з Excel</a>
    <a asp-action="Export" class="btn btn-secondary">Експорт у Excel</a>
</p>

    </tbody>
</table>


@model IEnumerable<DanceStudio.Domain.Model.SubscriptionType>

@{
    ViewData["Title"] = "Типи абонементів";
}

<h1>Танцювальна студія</h1>

<h2>Типи абонементів</h2>

<p>
    <a href="/SubscriptionTypes/Create" style="display: inline-block; padding: 5px 10px; background-color: #007bff; color: white; text-decoration: none; border-radius: 3px;">Додати тип</a>
</p>

<table style="width: 100%; border-collapse: collapse; margin-top: 20px;">
    <thead>
        <tr style="background-color: #f2f2f2;">
            <th style="padding: 10px; text-align: left; border-bottom: 1px solid #ddd;">ID</th>
            <th style="padding: 10px; text-align: left; border-bottom: 1px solid #ddd;">Назва</th>
            <th style="padding: 10px; text-align: left; border-bottom: 1px solid #ddd;">Сума</th>
            <th style="padding: 10px; text-align: left; border-bottom: 1px solid #ddd;">Опис</th>
            <th style="padding: 10px; text-align: left; border-bottom: 1px solid #ddd;">Кількість абонементів</th>
            <th style="padding: 10px; text-align: left; border-bottom: 1px solid #ddd;">Дії</th>
         </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
         <tr>
            <td style="padding: 10px; border-bottom: 1px solid #ddd;">@item.Id</td>
            <td style="padding: 10px; border-bottom: 1px solid #ddd;">@item.Name</td>
            <td style="padding: 10px; border-bottom: 1px solid #ddd;">@item.Amount?.ToString("C")</td>
            <td style="padding: 10px; border-bottom: 1px solid #ddd;">@item.Description</td>
            <td style="padding: 10px; border-bottom: 1px solid #ddd;">@(item.Subscriptions?.Count ?? 0)</td>
            <td style="padding: 10px; border-bottom: 1px solid #ddd;">
                <a href="/SubscriptionTypes/Edit/@item.Id" style="color: #007bff;">Edit</a> |
                <a href="/SubscriptionTypes/Details/@item.Id" style="color: #17a2b8;">Details</a> |
                <a href="/SubscriptionTypes/Delete/@item.Id" style="color: #dc3545;">Delete</a>
            </td>
         </tr>
}
    </tbody>
</table>

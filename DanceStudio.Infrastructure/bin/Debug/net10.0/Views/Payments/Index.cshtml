@model IEnumerable<DanceStudio.Domain.Model.Payment>

@{
    ViewData["Title"] = "Оплати";
    string[] statuses = { "Очікує", "Оплачено", "Скасовано", "Повернуто" };
}

<h1>Танцювальна студія</h1>

<h2>Оплати</h2>

<p>
    <a href="/Payments/Create" style="display: inline-block; padding: 5px 10px; background-color: #007bff; color: white; text-decoration: none; border-radius: 3px;">Додати оплату</a>
</p>

<table style="width: 100%; border-collapse: collapse; margin-top: 20px;">
    <thead>
        <tr style="background-color: #f2f2f2;">
            <th style="padding: 10px; text-align: left; border-bottom: 1px solid #ddd;">ID</th>
            <th style="padding: 10px; text-align: left; border-bottom: 1px solid #ddd;">Сума</th>
            <th style="padding: 10px; text-align: left; border-bottom: 1px solid #ddd;">Метод</th>
            <th style="padding: 10px; text-align: left; border-bottom: 1px solid #ddd;">Статус</th>
            <th style="padding: 10px; text-align: left; border-bottom: 1px solid #ddd;">Дата</th>
            <th style="padding: 10px; text-align: left; border-bottom: 1px solid #ddd;">Абонемент ID</th>
            <th style="padding: 10px; text-align: left; border-bottom: 1px solid #ddd;">Дії</th>
         </thead>
    <tbody>
@foreach (var item in Model) {
         <tr>
            <td style="padding: 10px; border-bottom: 1px solid #ddd;">@item.Id</td>
            <td style="padding: 10px; border-bottom: 1px solid #ddd;">@item.Amount.ToString("C")</td>
            <td style="padding: 10px; border-bottom: 1px solid #ddd;">@item.PaymentMethod</td>
            <td style="padding: 10px; border-bottom: 1px solid #ddd;">@item.Status</td>
            <td style="padding: 10px; border-bottom: 1px solid #ddd;">@item.PaymentDate.ToString("dd.MM.yyyy")</td>
            <td style="padding: 10px; border-bottom: 1px solid #ddd;">@item.Subscription_ID</td>
            <td style="padding: 10px; border-bottom: 1px solid #ddd;">
                <a href="/Payments/Edit/@item.Id" style="color: #007bff;">Edit</a> |
                <a href="/Payments/Details/@item.Id" style="color: #17a2b8;">Details</a> |
                <a href="/Payments/Delete/@item.Id" style="color: #dc3545;">Delete</a>
            </td>
         </tr>
}
    </tbody>
</table>

